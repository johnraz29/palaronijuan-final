<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
    <link rel="stylesheet" href="/register.css" />
</head>
<body>
    <div class="register-container">
        <section class="register-box">
            <div class="logo">
                <img src="LOGO_!23.png" alt="Logo">
            </div>

            <% if (step === 'input') { %>
                <h2>Create Account</h2>
                <form method="post" action="/register">
                    <label>
                        Full Name
                        <input name="name" type="text" placeholder="Juan Dela Cruz" required />
                    </label>
                    <label>
                        Phone Number
                        <input name="phone" type="text" placeholder="09123456789" required />
                    </label>
                    <label>
                        Email
                        <input name="email" type="email" placeholder="email@example.com" required />
                    </label>
                    <label>
                        Password
                        <input name="password" type="password" placeholder="Min. 6 characters" required />
                    </label>
                    <button type="submit">Send OTP</button>
                </form>
            <% } else if (step === 'verify') { %>
                <h2>Verify OTP</h2>
                <p>Nag-send kami ng code sa <strong><%= phone %></strong></p>
                <form method="post" action="/verify-otp">
                    <label>
                        Enter 6-Digit Code
                        <input name="otp_input" type="text" maxlength="6" placeholder="123456" required style="text-align: center; font-size: 20px; letter-spacing: 5px;" />
                    </label>
                    <button type="submit">Verify & Register</button>
                </form>
                <a href="/register" style="display:block; margin-top: 10px; text-decoration: none; color: gray;">Back to Register</a>
            <% } %>

            <footer>
                <p>&copy; <%= new Date().getFullYear() %> Lottery App. All rights reserved.</p>
            </footer>
        </section>
    </div>
</body>
</html>